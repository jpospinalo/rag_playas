# AWS S3 (almacenamiento centralizado del pipeline de datos)
S3_BUCKET_NAME=nombre-de-tu-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# Gemini (usado si OPENROUTER_API_KEY no está definida)
GOOGLE_API_KEY=tu_api_key_de_google
GEMINI_MODEL=gemma-3-27b-it

# OpenRouter (tiene prioridad sobre Gemini cuando está definida)
# Obtén tu clave en: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

# Chroma
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=rag_playas_5_docs

# Embeddings (Ollama)
OLLAMA_EMBED_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=embeddinggemma:latest

# Reranker (opcional, también con Ollama)
OLLAMA_RERANK_BASE_URL=http://127.0.0.1:11434
OLLAMA_RERANK_MODEL=llama3.2:3b

# ── Enriquecimiento de consultas ─────────────────────────────────────────────
# Activa el paso de reescritura de la consulta del usuario antes de la recuperación.
# El LLM enriquece la query con terminología jurídica precisa para mejorar el
# recall del retriever híbrido BM25 + vector.
QUERY_ENRICHMENT_ENABLED=true

# Activa la generación de un fragmento hipotético de sentencia (HyDE) como parte
# del enriquecimiento. Mejora la búsqueda vectorial para consultas abstractas,
# pero añade ~200 ms de latencia adicional al paso de enriquecimiento.
QUERY_ENRICHMENT_HYDE=false

# delay gemma
RAGAS_LLM_DELAY = 20.0
RATE_LIMIT_SECONDS = 20.0

# ── Evaluación ──────────────────────────────────────────────────────────────
# Segunda API key para el juez RAGAS (evita conflictos de rate-limit con el pipeline)
GOOGLE_API_KEY2=

# Evaluación con Ollama remoto (e.g., ngrok tunnel)
OLLAMA_EVAL_BASE_URL=http://localhost:11434
OLLAMA_EVAL_MODEL=mistral
